// BUFFER
#define SAMPLE_COUNT 128
#define SAMPLING_FREQUENCY 16000
//
double vReal[SAMPLE_COUNT];
double vImag[SAMPLE_COUNT];
int samples[SAMPLE_COUNT];
int sampleIdx = 0;

ArduinoFFT<double> FFT = ArduinoFFT<double>(vReal, vImag, SAMPLE_COUNT, SAMPLING_FREQUENCY);

// KẾT QUẢ
float BD_TrungBinh = 0;
float dB = 0;

//  TÍNH TOÁN 
void calculateSound() {
  if (SAMPLE_COUNT == 0) return;

  long long Tong_BP = 0;
  double tong_tri_tuyet_doi = 0;
  
  // 1. Tính trung bình thực tế của các mẫu này để khử nhiễu DC 
  long sum_adc = 0;
  for (int i = 0; i < SAMPLE_COUNT; i++) {
    sum_adc += samples[i];
  }
  float diemgiua = (float)sum_adc / SAMPLE_COUNT;

  // 2. Tính toán Biên độ và RMS
  for (int i = 0; i < SAMPLE_COUNT; i++) {
    float chenhlech = (float)samples[i] - diemgiua; // Lấy mẫu trừ đi diemgiua
    
    tong_tri_tuyet_doi += abs(chenhlech);
    Tong_BP += (long)(chenhlech * chenhlech);
  }

  // Cập nhật Biên độ trung bình 
  BD_TrungBinh = (float)tong_tri_tuyet_doi / SAMPLE_COUNT;

  // 3. Tính dB (RMS)
  float rms = sqrt((float)Tong_BP / SAMPLE_COUNT);
  
  if (rms > 0.5) { 
    // Ngưỡng chống nhiễu nhẹ
    // Công thức dB: 20*log10(rms). 
    // Cộng thêm một số để khớp với thực tế 
    dB = 20 * log10(rms) + 15 ; 
  } else {
    dB = 0;
  }
}

