// Hàm chỉ gửi Dữ liệu dạng JSON - Cực nhẹ
void handleData() {
  char jsonResponse[128];
  // Sử dụng snprintf để điền giá trị vào chuỗi JSON một cách an toàn
  snprintf(jsonResponse, sizeof(jsonResponse), 
    "{\"dB\":%.1f,\"amp\":%.2f}", 
    dB, BD_TrungBinh );
  
  server.send(200, "application/json", jsonResponse);
}
// ===== SETUP =====
void setup() {
  Serial.begin(115200);

  // ⚠️ QUAN TRỌNG: khai báo đúng chân UART2
  Serial2.begin(115200, SERIAL_8N1, 16, 17);

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\nWiFi OK");
  Serial.println(WiFi.localIP());

  server.on("/", handleRoot);
  server.on("/data", handleData);
  server.begin();
}

// ===== LOOP =====
void loop() {
  server.handleClient();

  // ===== ĐỌC UART BINARY (NHANH - CHÍNH XÁC) =====
 while (Serial2.available() > 0 && Serial2.peek() != 0xAA) {
    Serial2.read(); // Vứt bỏ các byte không phải 0xAA
  }

  // 2. Bây giờ, nếu bộ đệm có ít nhất 3 byte và byte đầu ĐÃ LÀ 0xAA
  if (Serial2.available() >= 3) {
    uint8_t header = Serial2.read(); // Đọc bỏ byte 0xAA
    uint8_t high = Serial2.read();
    uint8_t low  = Serial2.read();
    
    int val = (high << 😎 | low;

    // Cập nhật giá trị hiển thị và lưu vào buffer
    Gia_Tri_ADC = val;
    samples[sampleIdx++] = val;

    // Debug ra Serial Monitor (có thể tắt đi khi chạy ổn định)
    // Serial.printf("Read Binary: %d\n", val);

    // 4. Đủ mẫu → Tính toán (Giữ nguyên logic của bạn)
    if (sampleIdx >= SAMPLE_COUNT) {
      calculateSound();
      sampleIdx = 0;

      Serial.print("Amp: ");
      Serial.print(BD_TrungBinh);
      Serial.print(" | dB: ");
      Serial.println(dB);
      
      // Lưu ý: Đã dùng Binary thì không nên dùng delay(200) ở đây 
      // vì có thể làm tràn bộ đệm UART nếu dữ liệu về liên tục.
    }
  }
}
