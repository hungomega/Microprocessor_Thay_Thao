#include <WiFi.h>
#include <WebServer.h>
#include <math.h>

// ===== WIFI =====
const char* ssid = "ChungVip 2.4G";
const char* password = "123456789";

WebServer server(80);

// ===== BUFFER =====
#define SAMPLE_COUNT 20
int samples[SAMPLE_COUNT];
int sampleIdx = 0;

// ===== RESULT =====
float BD_TrungBinh = 0;
float dB = 0;
int Gia_Tri_ADC = 0;

// ===== TÍNH TOÁN =====
void calculateSound() {
  if (SAMPLE_COUNT == 0) return;

  long long Tong_BP = 0;
  double tong_tri_tuyet_doi = 0;
  
  // 1. Tính trung bình thực tế của mẻ mẫu này để khử nhiễu DC (DC Offset removal)
  long sum_adc = 0;
  for (int i = 0; i < SAMPLE_COUNT; i++) {
    sum_adc += samples[i];
  }
  float thuc_te_zero = (float)sum_adc / SAMPLE_COUNT;

  // 2. Tính toán Biên độ và RMS
  for (int i = 0; i < SAMPLE_COUNT; i++) {
    float deviation = (float)samples[i] - thuc_te_zero; // Lấy mẫu trừ đi điểm Zero thực tế
    
    tong_tri_tuyet_doi += abs(deviation);
    Tong_BP += (long)(deviation * deviation);
  }

  // Cập nhật Biên độ trung bình (Amplitude)
  BD_TrungBinh = (float)tong_tri_tuyet_doi / SAMPLE_COUNT;

  // 3. Tính dB (RMS)
  float rms = sqrt((float)Tong_BP / SAMPLE_COUNT);
  
  if (rms > 0.5) { // Ngưỡng chống nhiễu nhẹ
    // Công thức dB: 20*log10(rms). 
    // Cộng thêm một số (ví dụ +30) để khớp với thực tế nếu cần (Calibration)
    dB = 20 * log10(rms) + 20; 
  } else {
    dB = 0;
  }
  
  // Cập nhật giá trị ADC cuối cùng để hiển thị web
  Gia_Tri_ADC = samples[SAMPLE_COUNT - 1]; 
}

// ===== WEB =====
