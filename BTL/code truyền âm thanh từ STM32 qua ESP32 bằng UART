#include "stm32f10x.h"
#include "stdio.h"

// ===== KHỞI TẠO UART1 =====
void UART1_Init(void)
{
    RCC->APB2ENR |= (1 << 2);   // Bật clock cho GPIOA 
    RCC->APB2ENR |= (1 << 14);    // Bật clock cho USART1

    // Cấu hình chân PA9 (TX) là Alternate Function Push-Pull, tốc độ 50MHz
    GPIOA->CRH &= ~(0xF << 4);    // Xóa cấu hình cũ của PA9
    GPIOA->CRH |=  (0xB << 4);    // MODE=11 (50MHz), CNF=10 (AF Push-Pull)

    // Cấu hình chân PA10 (RX) là Input Floating
    GPIOA->CRH &= ~(0xF << 8);    // Xóa cấu hình cũ của PA10
    GPIOA->CRH |=  (0x4 << 8);    // MODE=00 (input), CNF=01 (floating)

    USART1->BRR = 0x271;          // Thiết lập baudrate = 9600 với clock 72MHz

    // Baucáu
    USART1->CR1 |= (1 << 13) | (1 << 3); // UE=1 (enable USART), TE=1 (enable transmit)
}

// ===== GỬI 1 BYTE QUA UART =====
void UART1_SendByte(uint8_t b)
{
    // Chờ cho đến khi thanh ghi truyền rỗng (TXE = 1)
    while (!(USART1->SR & (1 << 7)))
		{
		//	TXE = 1 
		}

    // Ghi dữ liệu vào thanh ghi DR để gửi đi
    USART1->DR = b;
}



// ===== GỬI MẢNG DỮ LIỆU DẠNG NHỊ PHÂN =====
void UART1_SendBuffer_Binary(uint16_t *pBuffer, uint16_t size)
{
    uint16_t i;
    for (i = 0; i < size; i++)
    {
        // 1. Gửi byte đồng bộ (Header) để thiết bị nhận (ESP32) biết bắt đầu khung dữ liệu
        UART1_SendByte(0xAA); 
        
        // 2. Gửi byte cao (8 bit cao của số 16 bit)
        UART1_SendByte((uint8_t)(pBuffer[i] >> 8));
        
        // 3. Gửi byte thấp (8 bit thấp)
        UART1_SendByte((uint8_t)(pBuffer[i] & 0xFF));
    }
}

void ADC1_Init(void)
{
    RCC->APB2ENR |= (1 << 2);   // GPIOA
    RCC->APB2ENR |= (1 << 9);   // ADC1

    // PA0 -> analog
    GPIOA->CRL &= ~(0xF << 0);

    ADC1->SQR3 = 0; // channel 0
    ADC1->CR2 |= (1 << 0); // ADON

    // Delay nh?
    for (int i = 0; i < 1000; i++);

    ADC1->CR2 |= (1 << 0); // b?t l?i l?n 2
}

// ===== ADC READ =====
uint16_t ADC1_Read(void)
{
    ADC1->CR2 |= (1 << 22); // start conversion
    while (!(ADC1->SR & (1 << 1))); // EOC
    return ADC1->DR;
}

// ===== MAIN =====
int main(void)
{
    UART1_Init();
    ADC1_Init();

    while (1)
    {
        uint16_t value = ADC1_Read();

        // Truyền địa chỉ của value và số phần tử = 1
        UART1_SendBuffer_Binary(&value, 1);

        for (int i = 0; i < 50000; i++); // delay
    }
}
