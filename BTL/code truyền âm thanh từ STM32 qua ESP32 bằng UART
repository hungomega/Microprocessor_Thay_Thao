#include "stm32f10x.h"
#include "stdio.h"

// ===== UART INIT =====
void UART1_Init(void)
{
    RCC->APB2ENR |= (1 << 2);   // GPIOA clock
    RCC->APB2ENR |= (1 << 14);  // USART1 clock

    // PA9 (TX) - AF Push Pull
    GPIOA->CRH &= ~(0xF << 4);
    GPIOA->CRH |=  (0xB << 4);

    // PA10 (RX) - Floating input
    GPIOA->CRH &= ~(0xF << 8);
    GPIOA->CRH |=  (0x4 << 8);

    USART1->BRR = 0x1D4C; // 9600 baud (72MHz)
    USART1->CR1 |= (1 << 13) | (1 << 3); // UE, TE
}

// ===== UART SEND =====
void UART1_SendChar(char c)
{
    while (!(USART1->SR & (1 << 7))); // TXE
    USART1->DR = c;
}

void UART1_SendNumber(uint16_t num)
{
    char buffer[10];
    sprintf(buffer, "%d\r\n", num);

    for (int i = 0; buffer[i] != '\0'; i++)
    {
        UART1_SendChar(buffer[i]);
    }
}

// ===== ADC INIT =====
void ADC1_Init(void)
{
    RCC->APB2ENR |= (1 << 2);   // GPIOA
    RCC->APB2ENR |= (1 << 9);   // ADC1

    // PA0 -> analog
    GPIOA->CRL &= ~(0xF << 0);

    ADC1->SQR3 = 0; // channel 0
    ADC1->CR2 |= (1 << 0); // ADON

    // Delay nh?
    for (int i = 0; i < 1000; i++);

    ADC1->CR2 |= (1 << 0); // b?t l?i l?n 2
}

// ===== ADC READ =====
uint16_t ADC1_Read(void)
{
    ADC1->CR2 |= (1 << 22); // start conversion
    while (!(ADC1->SR & (1 << 1))); // EOC
    return ADC1->DR;
}

// ===== MAIN =====
int main(void)
{
    UART1_Init();
    ADC1_Init();

    while (1)
    {
        uint16_t value = ADC1_Read();
        UART1_SendNumber(value);

        for (int i = 0; i < 50000; i++); // delay
    }
}

