#include "stm32f10x.h"

uint8_t seg[10] = {
  0xC0,0xF9,0xA4,0xB0,0x99,
  0x92,0x82,0xF8,0x80,0x90
};

void delay(int t)
{
    for(int i=0;i<t*8000;i++);
}

void display(int num)
{
    int chuc = num / 10;
    int donvi = num % 10;

    // digit 1
    GPIOA->ODR |= (1<<3);
    GPIOA->ODR &= ~(1<<4);
    GPIOB->ODR = seg[chuc];
    delay(1);

    // digit 2
    GPIOA->ODR |= (1<<4);
    GPIOA->ODR &= ~(1<<3);
    GPIOB->ODR = seg[donvi];
    delay(1);
}

void countdown(int time)
{
    for(int t = time; t >= 0; t--)
    {
        for(int i=0;i<500;i++)
            display(t);
    }
}

int main()
{
    // bật clock GPIOA, GPIOB
    RCC->APB2ENR |= (1<<2) | (1<<3);

    // PA0-PA4 output
    GPIOA->CRL = 0x11111;

    // PORTB output (7 đoạn)
    GPIOB->CRL = 0x33333333;

    while(1)
    {
        // 🔴 ĐỎ (PA0) - 15s
        GPIOA->ODR = (1<<0);
        countdown(15);

        // 🟢 XANH (PA1) - 12s
        GPIOA->ODR = (1<<1);
        countdown(12);

        // 🟡 VÀNG (PA2) - 3s
        GPIOA->ODR = (1<<2);
        countdown(3);
    }
}
