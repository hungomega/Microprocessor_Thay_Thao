#include "stm32f10x.h"

// ================= UART INIT =================
void UART_Init()
{
    // B1: c?p clock GPIOA + USART1
    RCC->APB2ENR |= (1<<2);   // GPIOA
    RCC->APB2ENR |= (1<<14);  // USART1

    // B2: PA9 (TX) = AF Push-Pull
    GPIOA->CRH &= ~(0xF << 4);
    GPIOA->CRH |=  (0xB << 4);

    // B2: PA10 (RX) = Input Floating
    GPIOA->CRH &= ~(0xF << 8);
    GPIOA->CRH |=  (0x4 << 8);

    // B3: Baudrate 9600 (8MHz)
    USART1->BRR = 0x341;

    // B4: Enable USART + TX + RX
    USART1->CR1 |= (1<<13); // UE
    USART1->CR1 |= (1<<3);  // TE
    USART1->CR1 |= (1<<2);  // RE
}

// ================= RECEIVE 1 CHAR =================
char UART_ReceiveChar()
{
    while(!(USART1->SR & (1<<5))); // ch? RXNE = 1
    return USART1->DR;             // d?c d? li?u
}

// ================= MAIN =================
int main()
{
    UART_Init();

    char c;

    while(1)
    {
        c = UART_ReceiveChar(); // nh?n ký t?

        // g?i l?i d? test (echo)
        while(!(USART1->SR & (1<<7)));
        USART1->DR = c;
    }
}


