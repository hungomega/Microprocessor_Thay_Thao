	GPIO_InitTypeDef GPIO; 
	
void delay(int time){
	while(time)
	{
		SysTick -> LOAD = 72000 - 1;
		SysTick -> VAL  = 0;
		SysTick -> CTRL = 5;
		while(!(SysTick -> CTRL & ( 1 << 16))){/*wwait for COUNTFLAG*/}
		--time;
	}
}

uint16_t led7seg[10] = {0xC0, 0xF9, 0xA4,0xB0, 0x99, 0x92, 0x82, 0xF8, 0x80, 0x90};

void GPIO_Conf(){
	RCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOA,ENABLE);   //B1:cap clocck cho port A
	
                     //B2: cau hinh led output, 50Mhz, push-pull
	GPIO.GPIO_Mode = GPIO_Mode_Out_PP;
	GPIO.GPIO_Pin = GPIO_Pin_0 | GPIO_Pin_1 | GPIO_Pin_2 | GPIO_Pin_3 | GPIO_Pin_4 | GPIO_Pin_5 | GPIO_Pin_6 | GPIO_Pin_7;
	GPIO.GPIO_Speed = GPIO_Speed_50MHz;
	GPIO_Init(GPIOA, &GPIO);
	
	RCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOB, ENABLE);
	GPIO.GPIO_Mode = GPIO_Mode_Out_PP;
	GPIO.GPIO_Pin = GPIO_Pin_0 | GPIO_Pin_1;
	GPIO.GPIO_Speed = GPIO_Speed_50MHz;
	GPIO_Init(GPIOB, &GPIO);
	
	
}


GPIO_InitTypeDef GPIO_InitStruct;

void GPIO_InitInput()
{
    RCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOB, ENABLE);
    GPIO_InitStruct.GPIO_Mode  = GPIO_Mode_IPU;
    GPIO_InitStruct.GPIO_Pin   = GPIO_Pin_0;
    GPIO_InitStruct.GPIO_Speed = GPIO_Speed_50MHz;
    GPIO_Init(GPIOB, &GPIO_InitStruct);
}

void GPIO_InitOutPut()
{
    RCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOA, ENABLE);
    GPIO_InitStruct.GPIO_Mode  = GPIO_Mode_Out_PP;
    GPIO_InitStruct.GPIO_Pin   = GPIO_Pin_1;
    GPIO_InitStruct.GPIO_Speed = GPIO_Speed_50MHz;
    GPIO_Init(GPIOA, &GPIO_InitStruct);
}



int ngto(int a){
	if(a<2) return 0;
	else{
		for(int i=2;i<=sqrt(a);i++){
			if(a%i==0) return 0;
		}
	}
	return 1;
}

int chinhphuong(int a){
	if (a==1 || a==0) return 1;
	for(int i=1;i<=a/2;i++){
		if(i*i==a) return 1;	
	}
	return 0;
}


int main()
{
	GPIO_Conf();
	while(1)
	{

		int i, j;
		
			 		for(i = 1; i < 10; i++)
		{
	
			for(j = 0; j < 30; j++)
			{
				GPIOA->ODR = 0xBF ;
				GPIO_SetBits(GPIOB, GPIO_Pin_0);
